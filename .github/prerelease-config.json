{
  "release-type": "php",
  "prerelease": true,
  "prerelease-type": "rc",
  "versioning": "prerelease",
  "include-component-in-tag": false,
  "pull-request-title-pattern": "chore(release): release ${version}",
  "packages": {
    ".": {
      "package-name": "accessibility-exchange/branching-test",
      "extra-files": [
        {
          "type": "json",
          "path": ".github/pre-release-manifest.json",
          "jsonpath": "$[\".\"]"
        }
      ]
    }
  }
}
